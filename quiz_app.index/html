<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>クイズアプリ</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=M+PLUS+Rounded+1c:wght@400;700;800;900&display=swap" rel="stylesheet">
<style>
:root{
  --bg-start:#f5f3ff;
  --bg-end:#fdf2f8;
  --card:#ffffff;
  --border:#e9d5ff;
  --text:#3b0764;
  --muted:#9d7bb0;
  --primary:#8b5cf6;
  --primary2:#ec4899;
  --primary-dark:#7c3aed;
  --danger:#f43f5e;
  --success:#22c55e;
  --warning:#fbbf24;
}
*{box-sizing:border-box;}
body{
  margin:0;
  font-family:'M PLUS Rounded 1c', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  background:linear-gradient(160deg, var(--bg-start), var(--bg-end));
  background-attachment:fixed;
  color:var(--text);
  min-height:100vh;
}
.container{
  max-width:640px;
  margin:0 auto;
  padding:32px 20px 60px;
}
h1{
  font-size:26px;
  font-weight:800;
  margin:0 0 20px;
  background:linear-gradient(135deg, var(--primary-dark), var(--primary2));
  -webkit-background-clip:text;
  background-clip:text;
  -webkit-text-fill-color:transparent;
  display:inline-block;
}
.card{
  background:var(--card);
  border:2px solid #f3e8ff;
  border-radius:20px;
  padding:18px;
  margin-bottom:14px;
  box-shadow:0 4px 16px rgba(139,92,246,0.12);
  transition:transform 0.15s ease, box-shadow 0.15s ease;
}
.card:hover{ transform:translateY(-2px); box-shadow:0 8px 22px rgba(139,92,246,0.18); }
.card-title{font-weight:700;font-size:16px;}
.card-sub{color:var(--muted);font-size:13px;margin-top:4px;font-weight:700;}
.card-actions{margin-top:12px;display:flex;gap:8px;flex-wrap:wrap;}
button{
  font-family:inherit;
  font-size:14px;
  font-weight:700;
  padding:10px 20px;
  border-radius:999px;
  border:none;
  background:linear-gradient(135deg, var(--primary-dark), var(--primary2));
  color:#fff;
  cursor:pointer;
  box-shadow:0 4px 14px rgba(139,92,246,0.35);
  transition:transform 0.15s ease, box-shadow 0.15s ease;
}
button:hover{ transform:translateY(-1px) scale(1.03); box-shadow:0 6px 18px rgba(139,92,246,0.45); }
button:active{ transform:translateY(0) scale(0.97); }
button.secondary{background:#fff;color:var(--primary-dark);border:2px solid #e9d5ff;box-shadow:none;}
button.secondary:hover{background:#faf5ff;}
button.danger{background:#fff;color:var(--danger);border:2px solid #fecdd3;box-shadow:none;}
button.danger:hover{background:#fff1f2;}
button.link{background:none;border:none;color:var(--primary-dark);padding:0;margin-bottom:16px;font-size:14px;box-shadow:none;font-weight:700;}
button.link:hover{transform:none;text-decoration:underline;box-shadow:none;}
button:disabled{opacity:0.4;cursor:not-allowed;transform:none;box-shadow:none;}
.top-actions{display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap;}

form label{display:block;margin-bottom:14px;font-size:14px;font-weight:700;}
form textarea, form input[type=text], form input[type=number]{
  width:100%;
  margin-top:6px;
  padding:10px 12px;
  border:2px solid #e9d5ff;
  border-radius:12px;
  font-family:inherit;
  font-size:14px;
  background:#fff;
}
form textarea:focus, form input:focus{ outline:none; border-color:var(--primary); }
.choice-row{display:flex;align-items:center;gap:8px;margin-bottom:8px;}
.choice-row input[type=text]{flex:1;margin-top:0;}
.form-actions{margin-top:20px;display:flex;gap:8px;}

.quiz-progress{color:var(--primary-dark);font-size:14px;font-weight:800;margin-bottom:8px;}
.timer-bar{height:10px;background:#f3e8ff;border-radius:999px;overflow:hidden;margin-bottom:6px;}
.timer-fill{height:100%;border-radius:999px;background:var(--success);transition:width 0.3s linear, background-color 0.3s linear;}
.timer-text{font-size:13px;color:var(--muted);margin-bottom:18px;font-weight:700;}
.question-text{font-size:19px;font-weight:800;margin-bottom:20px;line-height:1.5;white-space:pre-wrap;}
.choices{display:flex;flex-direction:column;gap:10px;}
.choice-btn{
  background:#fff;
  color:var(--text);
  border:2px solid #f3e8ff;
  border-radius:16px;
  text-align:left;
  padding:14px 16px;
  font-size:15px;
  font-weight:700;
  box-shadow:0 2px 8px rgba(139,92,246,0.08);
}
.choice-btn:hover:not(:disabled){border-color:var(--primary);background:#faf5ff;transform:translateY(-2px);}
.choice-btn.correct{background:#ecfdf5;border-color:var(--success);color:#15803d;}
.choice-btn.incorrect{background:#fff1f2;border-color:var(--danger);color:#be123c;}
.feedback{margin-top:18px;padding:14px 16px;border-radius:16px;font-weight:800;font-size:16px;}
.feedback.correct{background:#ecfdf5;color:#15803d;}
.feedback.incorrect{background:#fff1f2;color:#be123c;}

.score{font-size:22px;font-weight:800;margin-bottom:6px;}
.score-pct{color:var(--muted);font-size:14px;margin-bottom:20px;font-weight:700;}
.result-row{border-left:5px solid var(--border);}
.result-row.correct{border-left-color:var(--success);}
.result-row.incorrect{border-left-color:var(--danger);}
.result-row div{margin-bottom:4px;font-size:14px;}
.result-row div:first-child{font-weight:700;font-size:15px;margin-bottom:8px;}
.empty{color:var(--muted);font-size:14px;padding:24px 0;text-align:center;font-weight:700;}

.rank-card{
  text-align:center;
  background:linear-gradient(135deg,#7c3aed,#ec4899);
  border-radius:24px;
  padding:32px 20px;
  margin-bottom:20px;
  color:#fff;
  box-shadow:0 8px 24px rgba(124,58,237,0.32);
}
.rank-emoji{font-size:60px;line-height:1;margin-bottom:8px;}
.rank-label{font-size:24px;font-weight:800;margin-bottom:4px;}
.rank-sub{font-size:14px;opacity:0.92;font-weight:700;}
button.fun{background:linear-gradient(135deg,#f43f5e,#ec4899);}

.home-hero{
  position:relative;
  text-align:center;
  background:linear-gradient(135deg,#ffe3f0 0%,#f3e8ff 55%,#e0f2ff 100%);
  border-radius:28px;
  padding:34px 20px 30px;
  margin-bottom:22px;
  overflow:hidden;
  box-shadow:0 10px 30px rgba(236,72,153,0.18);
}
.home-hero::before, .home-hero::after{
  content:'';
  position:absolute;
  border-radius:50%;
  background:rgba(255,255,255,0.55);
}
.home-hero::before{ width:90px; height:90px; top:-32px; left:-24px; }
.home-hero::after{ width:60px; height:60px; bottom:-22px; right:-12px; }
.hero-badge{
  display:inline-block;
  background:#fff;
  color:var(--primary2);
  font-size:12px;
  font-weight:800;
  letter-spacing:0.06em;
  padding:5px 16px;
  border-radius:999px;
  margin-bottom:14px;
  box-shadow:0 2px 10px rgba(236,72,153,0.22);
}
.home-hero h1{ font-size:30px; margin:0 0 8px; }
.hero-sub{ font-size:14px; color:#a15a8e; font-weight:700; margin-bottom:10px; }
.hero-deco{ font-size:20px; letter-spacing:10px; opacity:0.85; }

.streak-popup{
  position:fixed;
  top:22%;
  left:50%;
  transform:translate(-50%,-50%);
  z-index:10000;
  pointer-events:none;
  text-align:center;
  animation:streakPop 1.4s ease forwards;
}
.streak-popup .streak-badge{ font-size:46px; line-height:1; }
.streak-popup .streak-text{
  margin-top:4px;
  display:inline-block;
  background:linear-gradient(135deg,#fbbf24,#f43f5e);
  color:#fff;
  font-weight:900;
  font-size:22px;
  padding:8px 22px;
  border-radius:999px;
  box-shadow:0 10px 26px rgba(244,63,94,0.4);
  white-space:nowrap;
}
@keyframes streakPop{
  0%{ transform:translate(-50%,-50%) scale(0.4); opacity:0; }
  12%{ transform:translate(-50%,-50%) scale(1.2); opacity:1; }
  25%{ transform:translate(-50%,-50%) scale(1); opacity:1; }
  78%{ transform:translate(-50%,-50%) scale(1); opacity:1; }
  100%{ transform:translate(-50%,-65%) scale(0.85); opacity:0; }
}
.streak-chip{
  display:inline-block;
  margin-left:8px;
  background:linear-gradient(135deg,#fbbf24,#f43f5e);
  color:#fff;
  font-size:12px;
  font-weight:800;
  padding:3px 10px;
  border-radius:999px;
}

#confetti-canvas{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9999;}
</style>
</head>
<body>
<div id="app"></div>

<script>
const STORAGE_KEY = 'quizAppData_v1';
const DEFAULT_TIME_LIMIT = 30;

function loadData(){
  try{
    const raw = localStorage.getItem(STORAGE_KEY);
    if(raw){
      const parsed = JSON.parse(raw);
      if(!Array.isArray(parsed.quizSets)) parsed.quizSets = [];
      if(!Array.isArray(parsed.importedExportIds)) parsed.importedExportIds = [];
      return parsed;
    }
  }catch(e){}
  return { quizSets: [], importedExportIds: [] };
}
function saveData(){ localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); }

let data = loadData();
let view = 'home';
let currentSetId = null;
let editingQuestionId = null;
let session = null;
let timerInterval = null;
let timeLeft = 0;

function uid(prefix){ return prefix + '_' + Date.now().toString(36) + Math.random().toString(36).slice(2,8); }
function getSet(id){ return data.quizSets.find(s=>s.id===id); }
function escapeHtml(str){
  return String(str==null?'':str).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

const app = document.getElementById('app');

function render(){
  let html = '';
  if(view==='home') html = renderHome();
  else if(view==='adminQuestions') html = renderAdminQuestions();
  else if(view==='adminQuestionForm') html = renderAdminQuestionForm();
  else if(view==='quiz') html = renderQuizView();
  else if(view==='result') html = renderResultView();
  app.innerHTML = html;
}

/* ---------- HOME ---------- */
function renderHome(){
  let listHtml = '';
  if(data.quizSets.length===0){
    listHtml = '<div class="empty">✨ クイズセットがまだありません。「✨ 新しいクイズセットを作成」から始めましょう。</div>';
  } else {
    listHtml = data.quizSets.map(s=>`
      <div class="card">
        <div class="card-title">📚 ${escapeHtml(s.name)}</div>
        <div class="card-sub">${s.questions.length}問</div>
        <div class="card-actions">
          <button onclick="startQuiz('${s.id}')" ${s.questions.length===0?'disabled':''}>▶️ 受験する</button>
          <button class="secondary" onclick="goToAdminQuestions('${s.id}')">⚙️ 問題を管理</button>
        </div>
      </div>
    `).join('');
  }
  return `
    <div class="container">
      <div class="home-hero">
        <span class="hero-badge">CAMPUS QUIZ TIME</span>
        <h1>🎀 クイズアプリ</h1>
        <div class="hero-sub">授業の復習を、かわいく楽しく♪</div>
        <div class="hero-deco">🌸 ✨ 📖 ✨ 🌸</div>
      </div>
      ${listHtml}
      <div class="top-actions">
        <button onclick="createQuizSet()">✨ 新しいクイズセットを作成</button>
        <button class="secondary" onclick="triggerImportPicker()">📥 クイズを読み込む</button>
        ${data.quizSets.length>0?'<button class="secondary" onclick="exportAllQuizSets()">📤 全部書き出す</button>':''}
      </div>
    </div>
  `;
}

function createQuizSet(){
  const name = prompt('クイズセットの名前を入力してください');
  if(!name) return;
  const newSet = { id: uid('set'), name: name, questions: [] };
  data.quizSets.push(newSet);
  saveData();
  goToAdminQuestions(newSet.id);
}

function renameQuizSet(id){
  const set = getSet(id);
  if(!set) return;
  const name = prompt('新しい名前を入力してください', set.name);
  if(!name) return;
  set.name = name;
  saveData();
  render();
}

function deleteQuizSet(id){
  if(!confirm('このクイズセットを削除しますか?問題も全て削除されます。')) return;
  data.quizSets = data.quizSets.filter(s=>s.id!==id);
  saveData();
  goHome();
}

function goToAdminQuestions(id){
  currentSetId = id;
  view = 'adminQuestions';
  render();
}

function goHome(){
  stopTimer();
  session = null;
  currentSetId = null;
  view = 'home';
  render();
}

/* ---------- EXPORT / IMPORT ---------- */
function downloadJSON(filename, obj){
  const blob = new Blob([JSON.stringify(obj, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = filename;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  setTimeout(()=>URL.revokeObjectURL(url), 2000);
}

function buildExportPayload(setIds){
  const sets = setIds ? data.quizSets.filter(s=>setIds.includes(s.id)) : data.quizSets;
  return {
    type: 'quizAppExport',
    version: 1,
    exportId: uid('exp'),
    exportedAt: new Date().toISOString(),
    quizSets: sets.map(s=>({ id: s.id, name: s.name, questions: s.questions }))
  };
}

function safeFileName(name){
  return String(name||'quiz').replace(/[^a-zA-Z0-9一-龠ぁ-んァ-ンー]/g,'_').slice(0,40) || 'quiz';
}

function exportQuizSet(setId){
  const set = getSet(setId);
  if(!set) return;
  downloadJSON('quiz_' + safeFileName(set.name) + '.json', buildExportPayload([setId]));
}

function exportAllQuizSets(){
  if(data.quizSets.length===0){ alert('書き出すクイズセットがありません'); return; }
  downloadJSON('quiz_all_' + Date.now() + '.json', buildExportPayload());
}

function importQuizData(payload, opts){
  opts = opts || {};
  if(!payload || !Array.isArray(payload.quizSets)){
    if(!opts.silent) alert('クイズデータの形式が正しくありません');
    return false;
  }
  if(payload.exportId && opts.dedupe && data.importedExportIds.includes(payload.exportId)){
    return false;
  }
  const importedNames = [];
  payload.quizSets.forEach(s=>{
    const newSet = {
      id: uid('set'),
      name: s && s.name ? s.name : '読み込まれたクイズ',
      questions: (s && Array.isArray(s.questions) ? s.questions : []).map(q=>({
        id: uid('q'),
        text: q && q.text ? q.text : '',
        choices: (q && Array.isArray(q.choices) ? q.choices.slice(0,4) : ['','','','']),
        correctIndex: (q && typeof q.correctIndex==='number') ? q.correctIndex : 0,
        timeLimit: (q && q.timeLimit) ? q.timeLimit : DEFAULT_TIME_LIMIT
      }))
    };
    data.quizSets.push(newSet);
    importedNames.push(newSet.name);
  });
  if(payload.exportId && !data.importedExportIds.includes(payload.exportId)){
    data.importedExportIds.push(payload.exportId);
  }
  saveData();
  if(!opts.silent){
    alert('✨ ' + importedNames.length + '件のクイズを読み込みました: ' + importedNames.join('、'));
  }
  view = 'home';
  render();
  return true;
}

function triggerImportPicker(){
  const input = document.createElement('input');
  input.type = 'file';
  input.accept = '.json,application/json';
  input.style.display = 'none';
  document.body.appendChild(input);
  input.addEventListener('change', function(){
    const file = input.files && input.files[0];
    if(input.parentNode) document.body.removeChild(input);
    if(!file) return;
    const reader = new FileReader();
    reader.onload = function(e){
      try{
        const json = JSON.parse(e.target.result);
        importQuizData(json, {});
      }catch(err){
        alert('JSONファイルの読み込みに失敗しました: ' + err.message);
      }
    };
    reader.readAsText(file);
  });
  input.click();
}

function tryAutoImportFromUrl(){
  try{
    const params = new URLSearchParams(window.location.search);
    const url = params.get('import');
    if(!url) return;
    fetch(url).then(function(r){ return r.json(); }).then(function(json){
      importQuizData(json, { silent:true, dedupe:true });
    }).catch(function(){ /* ignore network/parse errors for auto-import */ });
  }catch(e){}
}

/* ---------- ADMIN: QUESTION LIST ---------- */
function renderAdminQuestions(){
  const set = getSet(currentSetId);
  if(!set){ goHome(); return ''; }
  let listHtml = '';
  if(set.questions.length===0){
    listHtml = '<div class="empty">📭 問題がまだありません。「➕ 問題を追加」から作成しましょう。</div>';
  } else {
    listHtml = set.questions.map((q,idx)=>`
      <div class="card">
        <div class="card-title">${idx+1}. ${escapeHtml(q.text)}</div>
        <div class="card-sub">✅ 正解: ${escapeHtml(q.choices[q.correctIndex])} ／ ⏱️ 時間制限: ${q.timeLimit}秒</div>
        <div class="card-actions">
          <button class="secondary" onclick="editQuestion('${q.id}')">✏️ 編集</button>
          <button class="danger" onclick="deleteQuestion('${q.id}')">🗑️ 削除</button>
        </div>
      </div>
    `).join('');
  }
  return `
    <div class="container">
      <button class="link" onclick="goHome()">🏠 ホームへ戻る</button>
      <h1>📝 ${escapeHtml(set.name)} の問題管理</h1>
      <div class="top-actions">
        <button onclick="newQuestion()">➕ 問題を追加</button>
        <button class="secondary" onclick="renameQuizSet('${set.id}')">✏️ 名前を変更</button>
        <button class="secondary" onclick="exportQuizSet('${set.id}')">📤 このクイズを書き出す</button>
        <button class="danger" onclick="deleteQuizSet('${set.id}')">🗑️ クイズセットを削除</button>
      </div>
      ${listHtml}
    </div>
  `;
}

function newQuestion(){
  editingQuestionId = null;
  view = 'adminQuestionForm';
  render();
}

function editQuestion(qid){
  editingQuestionId = qid;
  view = 'adminQuestionForm';
  render();
}

function deleteQuestion(qid){
  if(!confirm('この問題を削除しますか?')) return;
  const set = getSet(currentSetId);
  set.questions = set.questions.filter(q=>q.id!==qid);
  saveData();
  render();
}

function cancelQuestionForm(){
  view = 'adminQuestions';
  render();
}

/* ---------- ADMIN: QUESTION FORM ---------- */
function renderAdminQuestionForm(){
  const set = getSet(currentSetId);
  if(!set){ goHome(); return ''; }
  let q = { text:'', choices:['','','',''], correctIndex:0, timeLimit:DEFAULT_TIME_LIMIT };
  if(editingQuestionId){
    const found = set.questions.find(x=>x.id===editingQuestionId);
    if(found) q = found;
  }
  const choicesHtml = [0,1,2,3].map(i=>`
    <div class="choice-row">
      <input type="radio" name="qf-correct" value="${i}" ${q.correctIndex===i?'checked':''}>
      <input type="text" id="qf-choice-${i}" value="${escapeHtml(q.choices[i]||'')}" placeholder="選択肢${i+1}">
    </div>
  `).join('');
  return `
    <div class="container">
      <button class="link" onclick="cancelQuestionForm()">← 戻る</button>
      <h1>${editingQuestionId?'✏️ 問題を編集':'✨ 問題を追加'}</h1>
      <form onsubmit="saveQuestion(event)">
        <label>📝 問題文
          <textarea id="qf-text" rows="3">${escapeHtml(q.text)}</textarea>
        </label>
        <label>🎯 選択肢(左のラジオボタンで正解を指定)</label>
        ${choicesHtml}
        <label>⏱️ 時間制限(秒)
          <input type="number" id="qf-timelimit" min="5" max="300" value="${q.timeLimit}">
        </label>
        <div class="form-actions">
          <button type="submit">💾 保存</button>
          <button type="button" class="secondary" onclick="cancelQuestionForm()">キャンセル</button>
        </div>
      </form>
    </div>
  `;
}

function saveQuestion(e){
  e.preventDefault();
  const text = document.getElementById('qf-text').value.trim();
  const choices = [0,1,2,3].map(i=>document.getElementById('qf-choice-'+i).value.trim());
  const correctRadio = document.querySelector('input[name="qf-correct"]:checked');
  const timeLimitRaw = parseInt(document.getElementById('qf-timelimit').value,10);
  const timeLimit = isNaN(timeLimitRaw) ? DEFAULT_TIME_LIMIT : Math.min(300, Math.max(5, timeLimitRaw));

  if(!text){ alert('問題文を入力してください'); return; }
  if(choices.some(c=>!c)){ alert('選択肢を全て入力してください'); return; }
  if(!correctRadio){ alert('正解を選択してください'); return; }

  const set = getSet(currentSetId);
  if(editingQuestionId){
    const q = set.questions.find(q=>q.id===editingQuestionId);
    q.text = text; q.choices = choices; q.correctIndex = parseInt(correctRadio.value,10); q.timeLimit = timeLimit;
  } else {
    set.questions.push({ id: uid('q'), text: text, choices: choices, correctIndex: parseInt(correctRadio.value,10), timeLimit: timeLimit });
  }
  saveData();
  view = 'adminQuestions';
  render();
}

/* ---------- QUIZ ---------- */
function startQuiz(setId){
  const set = getSet(setId);
  if(!set || set.questions.length===0) return;
  session = {
    setId: setId,
    order: set.questions.map(q=>q.id),
    index: 0,
    answers: [],
    answered: false,
    selectedIndex: null,
    streak: 0
  };
  view = 'quiz';
  render();
  startTimer();
}

function getCurrentQuestion(){
  const set = getSet(session.setId);
  if(!set) return null;
  const qid = session.order[session.index];
  return set.questions.find(q=>q.id===qid) || null;
}

function startTimer(){
  const q = getCurrentQuestion();
  if(!q) return;
  timeLeft = q.timeLimit || DEFAULT_TIME_LIMIT;
  stopTimer();
  render();
  timerInterval = setInterval(()=>{
    timeLeft--;
    if(timeLeft<=0){
      timeLeft = 0;
      stopTimer();
      handleTimeout();
    } else {
      render();
    }
  }, 1000);
}

function stopTimer(){
  if(timerInterval){ clearInterval(timerInterval); timerInterval = null; }
}

function recordAnswer(selectedIndex, timedOut){
  const q = getCurrentQuestion();
  if(!q) return;
  const correct = !timedOut && selectedIndex === q.correctIndex;
  session.answered = true;
  session.selectedIndex = selectedIndex;
  session.streak = correct ? (session.streak||0) + 1 : 0;
  session.answers.push({
    questionId: q.id,
    text: q.text,
    choices: q.choices,
    correctIndex: q.correctIndex,
    selectedIndex: selectedIndex,
    correct: correct,
    timedOut: !!timedOut
  });
}

function selectAnswer(i){
  if(!session || session.answered) return;
  stopTimer();
  recordAnswer(i, false);
  render();
  const last = session.answers[session.answers.length-1];
  if(last.correct){
    launchConfetti();
    if(session.streak >= 2) launchStreakPopup(session.streak);
  }
}

/* ---------- FUN: STREAK POPUP ---------- */
function launchStreakPopup(streak){
  const old = document.getElementById('streak-popup');
  if(old) old.remove();
  const el = document.createElement('div');
  el.id = 'streak-popup';
  el.className = 'streak-popup';
  el.innerHTML = '<div class="streak-badge">🔥</div><div class="streak-text">正解数 ' + streak + '!</div>';
  document.body.appendChild(el);
  setTimeout(()=>{ if(el.parentNode) el.remove(); }, 1400);
}

/* ---------- FUN: CONFETTI ---------- */
function launchConfetti(){
  const old = document.getElementById('confetti-canvas');
  if(old) old.remove();
  const canvas = document.createElement('canvas');
  canvas.id = 'confetti-canvas';
  document.body.appendChild(canvas);
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
  const ctx = canvas.getContext('2d');
  if(!ctx) return;
  const colors = ['#f43f5e','#fb923c','#facc15','#4ade80','#38bdf8','#a78bfa'];
  const particles = [];
  for(let i=0;i<90;i++){
    particles.push({
      x: Math.random()*canvas.width,
      y: -20 - Math.random()*canvas.height*0.4,
      w: 6+Math.random()*6,
      h: 4+Math.random()*4,
      color: colors[Math.floor(Math.random()*colors.length)],
      vy: 3+Math.random()*4,
      vx: -2+Math.random()*4,
      rot: Math.random()*360,
      vrot: -12+Math.random()*24
    });
  }
  let frame = 0;
  const maxFrames = 110;
  function animate(){
    frame++;
    ctx.clearRect(0,0,canvas.width,canvas.height);
    particles.forEach(p=>{
      p.x += p.vx;
      p.y += p.vy;
      p.rot += p.vrot;
      ctx.save();
      ctx.translate(p.x,p.y);
      ctx.rotate(p.rot*Math.PI/180);
      ctx.fillStyle = p.color;
      ctx.fillRect(-p.w/2,-p.h/2,p.w,p.h);
      ctx.restore();
    });
    if(frame<maxFrames && document.getElementById('confetti-canvas')){
      requestAnimationFrame(animate);
    } else if(canvas.parentNode){
      canvas.remove();
    }
  }
  animate();
}

function handleTimeout(){
  if(!session || session.answered) return;
  recordAnswer(null, true);
  render();
}

function nextQuestion(){
  session.index++;
  session.answered = false;
  session.selectedIndex = null;
  if(session.index >= session.order.length){
    stopTimer();
    view = 'result';
    render();
  } else {
    render();
    startTimer();
  }
}

function renderQuizView(){
  if(!session){ goHome(); return ''; }
  const q = getCurrentQuestion();
  if(!q){ stopTimer(); view = 'result'; return renderResultView(); }
  const total = session.order.length;
  const limit = q.timeLimit || DEFAULT_TIME_LIMIT;
  const pct = Math.max(0, Math.min(100, (timeLeft/limit)*100));
  let timerColor = 'var(--success)';
  if(pct < 25) timerColor = 'var(--danger)';
  else if(pct < 55) timerColor = 'var(--warning)';

  const labels = ['Ⓐ','Ⓑ','Ⓒ','Ⓓ'];
  const choicesHtml = q.choices.map((c,i)=>{
    let cls = 'choice-btn';
    if(session.answered){
      if(i===q.correctIndex) cls += ' correct';
      else if(i===session.selectedIndex) cls += ' incorrect';
    }
    return `<button class="${cls}" onclick="selectAnswer(${i})" ${session.answered?'disabled':''}>${labels[i]||''} ${escapeHtml(c)}</button>`;
  }).join('');

  let feedbackHtml = '';
  if(session.answered){
    const lastAnswer = session.answers[session.answers.length-1];
    if(lastAnswer.correct){
      feedbackHtml = `<div class="feedback correct">🎊 正解です!</div>`;
    } else if(lastAnswer.timedOut){
      feedbackHtml = `<div class="feedback incorrect">⏰ 時間切れです。正解は「${escapeHtml(q.choices[q.correctIndex])}」</div>`;
    } else {
      feedbackHtml = `<div class="feedback incorrect">😢 不正解です。正解は「${escapeHtml(q.choices[q.correctIndex])}」</div>`;
    }
    feedbackHtml += `<div class="form-actions"><button onclick="nextQuestion()">${session.index+1>=total?'🎉 結果を見る':'次の問題へ →'}</button></div>`;
  }

  return `
    <div class="container">
      <div class="quiz-progress">🎯 問題 ${session.index+1} / ${total}${session.streak>=2?`<span class="streak-chip">🔥${session.streak}連続</span>`:''}</div>
      <div class="timer-bar"><div class="timer-fill" style="width:${pct}%;background:${timerColor};"></div></div>
      <div class="timer-text">⏱️ 残り ${timeLeft}秒</div>
      <div class="card question-text">${escapeHtml(q.text)}</div>
      <div class="choices">${choicesHtml}</div>
      ${feedbackHtml}
    </div>
  `;
}

/* ---------- RESULT ---------- */
function getRank(pct){
  if(pct>=100) return {label:'パーフェクト!', emoji:'🏆', color:'#f59e0b'};
  if(pct>=80) return {label:'素晴らしい!', emoji:'🌟', color:'#10b981'};
  if(pct>=50) return {label:'もう少し!', emoji:'💪', color:'#3b82f6'};
  return {label:'チャレンジ中', emoji:'🔥', color:'#ef4444'};
}

function renderResultView(){
  if(!session){ return renderHome(); }
  const correctCount = session.answers.filter(a=>a.correct).length;
  const total = session.answers.length;
  const pct = total>0 ? Math.round((correctCount/total)*100) : 0;
  const rank = getRank(pct);
  const rowsHtml = session.answers.map((a,idx)=>{
    const selectedText = a.timedOut ? '(時間切れ・未回答)' : escapeHtml(a.choices[a.selectedIndex]);
    return `
      <div class="card result-row ${a.correct?'correct':'incorrect'}">
        <div>${idx+1}. ${escapeHtml(a.text)}</div>
        <div>${a.correct?'✅':'❌'} あなたの回答: ${selectedText}</div>
        <div>🎯 正解: ${escapeHtml(a.choices[a.correctIndex])}</div>
      </div>
    `;
  }).join('');
  return `
    <div class="container">
      <h1>🎊 結果発表</h1>
      <div class="rank-card">
        <div class="rank-emoji">${rank.emoji}</div>
        <div class="rank-label">${rank.label}</div>
        <div class="rank-sub">正解率 ${pct}%</div>
      </div>
      <div class="score">${correctCount} / ${total} 問正解</div>
      <div class="score-pct">正解率 ${pct}%</div>
      <div class="top-actions">
        <button class="fun" onclick="downloadScoreImage()">📸 スコア画像を保存</button>
        <button class="secondary" onclick="downloadResultTableImage()">📋 結果一覧を画像で保存</button>
      </div>
      ${rowsHtml}
      <div class="top-actions">
        <button onclick="goHome()">🏠 ホームへ戻る</button>
      </div>
    </div>
  `;
}

/* ---------- FUN: IMAGE DOWNLOADS ---------- */
function roundRect(ctx,x,y,w,h,r){
  ctx.beginPath();
  ctx.moveTo(x+r,y);
  ctx.arcTo(x+w,y,x+w,y+h,r);
  ctx.arcTo(x+w,y+h,x,y+h,r);
  ctx.arcTo(x,y+h,x,y,r);
  ctx.arcTo(x,y,x+w,y,r);
  ctx.closePath();
}

function wrapText(ctx, text, maxWidth){
  const chars = String(text==null?'':text).split('');
  const lines = [];
  let current = '';
  for(const ch of chars){
    const test = current + ch;
    if(current && ctx.measureText(test).width > maxWidth){
      lines.push(current);
      current = ch;
    } else {
      current = test;
    }
  }
  if(current) lines.push(current);
  return lines.length ? lines : [''];
}

function triggerDownload(canvas, filename){
  canvas.toBlob(function(blob){
    if(!blob) return;
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    setTimeout(()=>URL.revokeObjectURL(url), 2000);
  });
}

function downloadScoreImage(){
  if(!session) return;
  const set = getSet(session.setId);
  const setName = set ? set.name : 'クイズ';
  const correctCount = session.answers.filter(a=>a.correct).length;
  const total = session.answers.length;
  const pct = total>0 ? Math.round((correctCount/total)*100) : 0;
  const rank = getRank(pct);

  const canvas = document.createElement('canvas');
  canvas.width = 800;
  canvas.height = 1000;
  const ctx = canvas.getContext('2d');
  if(!ctx){ alert('お使いのブラウザでは画像生成に対応していません'); return; }

  const grad = ctx.createLinearGradient(0,0,800,1000);
  grad.addColorStop(0,'#667eea');
  grad.addColorStop(1,'#f093fb');
  ctx.fillStyle = grad;
  ctx.fillRect(0,0,800,1000);

  ctx.fillStyle = 'rgba(255,255,255,0.12)';
  ctx.beginPath(); ctx.arc(80,80,90,0,Math.PI*2); ctx.fill();
  ctx.beginPath(); ctx.arc(740,920,120,0,Math.PI*2); ctx.fill();
  ctx.beginPath(); ctx.arc(720,60,50,0,Math.PI*2); ctx.fill();

  ctx.fillStyle = 'rgba(255,255,255,0.97)';
  roundRect(ctx,60,150,680,710,28);
  ctx.fill();

  ctx.textAlign = 'center';
  ctx.fillStyle = '#9ca3af';
  ctx.font = '24px sans-serif';
  ctx.fillText('QUIZ RESULT', 400, 215);

  ctx.fillStyle = '#1f2937';
  ctx.font = 'bold 34px sans-serif';
  wrapText(ctx, setName, 560).slice(0,2).forEach((line,i)=>{
    ctx.fillText(line, 400, 270 + i*42);
  });

  ctx.font = '100px sans-serif';
  ctx.fillText(rank.emoji, 400, 440);

  ctx.font = 'bold 46px sans-serif';
  ctx.fillStyle = rank.color;
  ctx.fillText(rank.label, 400, 510);

  ctx.font = 'bold 120px sans-serif';
  ctx.fillStyle = '#1f2937';
  ctx.fillText(correctCount + ' / ' + total, 400, 660);

  ctx.font = '30px sans-serif';
  ctx.fillStyle = '#6b7280';
  ctx.fillText('正解率 ' + pct + '%', 400, 710);

  ctx.font = '20px sans-serif';
  ctx.fillStyle = '#9ca3af';
  const dateStr = new Date().toLocaleDateString('ja-JP');
  ctx.fillText(dateStr + '  ｜  クイズアプリ', 400, 820);

  triggerDownload(canvas, 'quiz_score_' + Date.now() + '.png');
}

function downloadResultTableImage(){
  if(!session) return;
  const set = getSet(session.setId);
  const setName = set ? set.name : 'クイズ';
  const correctCount = session.answers.filter(a=>a.correct).length;
  const total = session.answers.length;

  const rowsData = session.answers.map((a,idx)=>({
    no: String(idx+1),
    question: a.text,
    yourAnswer: a.timedOut ? '(時間切れ)' : a.choices[a.selectedIndex],
    correctAnswer: a.choices[a.correctIndex],
    result: a.correct ? '○ 正解' : '× 不正解'
  }));

  const colWidths = { no:50, question:340, yourAnswer:170, correctAnswer:170, result:120 };
  const padding = 12;
  const fontSize = 16;
  const lineHeight = 22;
  const headerHeight = 46;
  const titleHeight = 76;

  const tmpCanvas = document.createElement('canvas');
  const tctx = tmpCanvas.getContext('2d');
  if(!tctx){ alert('お使いのブラウザでは画像生成に対応していません'); return; }
  tctx.font = fontSize + 'px sans-serif';

  const rowLayouts = rowsData.map(r=>{
    const qLines = wrapText(tctx, r.question, colWidths.question - padding*2);
    const yLines = wrapText(tctx, r.yourAnswer, colWidths.yourAnswer - padding*2);
    const cLines = wrapText(tctx, r.correctAnswer, colWidths.correctAnswer - padding*2);
    const maxLines = Math.max(qLines.length, yLines.length, cLines.length, 1);
    return { height: Math.max(50, maxLines*lineHeight + padding*2), qLines, yLines, cLines };
  });

  const totalWidth = colWidths.no + colWidths.question + colWidths.yourAnswer + colWidths.correctAnswer + colWidths.result + padding*2;
  const totalHeight = titleHeight + headerHeight + rowLayouts.reduce((s,r)=>s+r.height,0) + 24;

  const canvas = document.createElement('canvas');
  canvas.width = totalWidth;
  canvas.height = totalHeight;
  const ctx = canvas.getContext('2d');
  if(!ctx){ alert('お使いのブラウザでは画像生成に対応していません'); return; }

  ctx.fillStyle = '#ffffff';
  ctx.fillRect(0,0,canvas.width,canvas.height);

  ctx.textAlign = 'left';
  ctx.fillStyle = '#1f2937';
  ctx.font = 'bold 24px sans-serif';
  ctx.fillText(setName + ' - 結果一覧', padding, 36);
  ctx.font = '16px sans-serif';
  ctx.fillStyle = '#6b7280';
  ctx.fillText('正解 ' + correctCount + ' / ' + total, padding, 62);

  let y = titleHeight;
  const headers = [
    { text:'No', w:colWidths.no },
    { text:'問題', w:colWidths.question },
    { text:'あなたの回答', w:colWidths.yourAnswer },
    { text:'正解', w:colWidths.correctAnswer },
    { text:'結果', w:colWidths.result }
  ];
  ctx.fillStyle = '#f3f4f6';
  ctx.fillRect(padding, y, totalWidth - padding*2, headerHeight);
  ctx.fillStyle = '#1f2937';
  ctx.font = 'bold ' + fontSize + 'px sans-serif';
  let x = padding;
  headers.forEach(h=>{
    ctx.fillText(h.text, x + padding, y + headerHeight/2 + 6);
    x += h.w;
  });
  y += headerHeight;

  rowsData.forEach((r,idx)=>{
    const rl = rowLayouts[idx];
    ctx.fillStyle = idx % 2 === 0 ? '#ffffff' : '#f9fafb';
    ctx.fillRect(padding, y, totalWidth - padding*2, rl.height);
    ctx.fillStyle = r.result.indexOf('○') === 0 ? '#16a34a' : '#dc2626';
    ctx.fillRect(padding, y, 4, rl.height);

    ctx.font = fontSize + 'px sans-serif';
    ctx.fillStyle = '#1f2937';
    x = padding;
    ctx.fillText(r.no, x + padding, y + rl.height/2 + 6);
    x += colWidths.no;
    rl.qLines.forEach((line,li)=>{
      ctx.fillText(line, x + padding, y + padding + lineHeight*(li+0.7));
    });
    x += colWidths.question;
    rl.yLines.forEach((line,li)=>{
      ctx.fillText(line, x + padding, y + padding + lineHeight*(li+0.7));
    });
    x += colWidths.yourAnswer;
    rl.cLines.forEach((line,li)=>{
      ctx.fillText(line, x + padding, y + padding + lineHeight*(li+0.7));
    });
    x += colWidths.correctAnswer;
    ctx.font = 'bold ' + fontSize + 'px sans-serif';
    ctx.fillStyle = r.result.indexOf('○') === 0 ? '#16a34a' : '#dc2626';
    ctx.fillText(r.result, x + padding, y + rl.height/2 + 6);

    y += rl.height;
  });

  ctx.strokeStyle = '#e5e7eb';
  ctx.lineWidth = 1;
  let lineX = padding;
  [colWidths.no, colWidths.question, colWidths.yourAnswer, colWidths.correctAnswer].forEach(w=>{
    lineX += w;
    ctx.beginPath();
    ctx.moveTo(lineX, titleHeight);
    ctx.lineTo(lineX, canvas.height - 8);
    ctx.stroke();
  });

  triggerDownload(canvas, 'quiz_result_' + Date.now() + '.png');
}

render();
tryAutoImportFromUrl();
</script>
